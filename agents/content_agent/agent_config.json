{
  "agent_type": "content",
  "agent_name": "内容Agent",
  "version": "1.0.0",
  "description": "负责生成具体的小说内容、场景描写、对话撰写",
  "capabilities": [
    {
      "name": "generate_content",
      "description": "生成小说内容",
      "parameters": {
        "outline": "大纲内容",
        "scene": "场景描述"
      }
    }
  ],
  "model": {
    "provider": "moonshot",
    "model_id": "kimi-k2.5",
    "temperature": 1.0,
    "max_tokens": 88192
  },
  "prompts": {
    "system_prompt": "prompts/system_prompt.md",
    "task_prompt": "prompts/task_prompt.md"
  },
  "registry": {
    "endpoint": "http://localhost:8000"
  },
  "tools": [
    {
      "name": "execute_bash",
      "module": "core.base.tools.bash_executor"
    },
    {
      "name": "read_skill_content",
      "module": "core.base.tools.skill_content_reader"
    },
    {
      "name": "execute_remote_mysql_command",
      "module": "core.base.tools.mysql_executor"
    }
  ]
}