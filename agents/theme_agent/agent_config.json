{
  "agent_type": "theme",
  "agent_name": "主题Agent",
  "version": "1.0.0",
  "description": "负责创建世界观、迭代世界观结构、查验世界观的合理性、给定相关内容确认世界观是否符合要求",
  "capabilities": [
    {
      "name": "创建世界观",
      "description": "根据给定的用户想法创建世界观",
      "parameters": {
        "task": "用户的想法描述"
      }
    }
  ],
  "model": {
    "provider": "moonshot",
    "model_id": "kimi-k2.5",
    "temperature": 1.0,
    "max_tokens": 88192
  },
  "prompts": {
    "system_prompt": "prompts/system_prompt.md",
    "task_prompt": "prompts/task_prompt.md"
  },
  "registry": {
    "endpoint": "http://localhost:8000"
  },
  "tools": [
    {
      "name": "execute_bash",
      "module": "core.base.tools.bash_executor"
    },
    {
      "name": "read_skill_content",
      "module": "core.base.tools.skill_content_reader"
    },
    {
      "name": "execute_remote_mysql_command",
      "module": "core.base.tools.mysql_executor"
    }
  ]
}
